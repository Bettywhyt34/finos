# ==================== DATABASE (Supabase) ====================
# Transaction pooler (port 6543) — Prisma runtime via pgBouncer
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Session pooler (port 5432) — Prisma Migrate & db pull
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres"

# ==================== APP URL ====================
NEXT_PUBLIC_APP_URL="https://finos-app.com"

# ==================== NEXTAUTH ====================
NEXTAUTH_URL="https://finos-app.com"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-strong-secret-here"

# ==================== GOOGLE OAUTH ====================
# Authorised redirect URI: https://finos-app.com/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==================== SUPABASE ====================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ==================== EMAIL (Resend) ====================
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="FINOS <noreply@finos-app.com>"

# ==================== ENCRYPTION ====================
# AES-256-GCM key for storing OAuth tokens at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-hex-char-encryption-key"

# ==================== UPSTASH REDIS (BullMQ sync queues) ====================
# Full Redis URL (rediss://), NOT the REST URL
UPSTASH_REDIS_URL="rediss://default:[TOKEN]@[HOST].upstash.io:6379"

# ==================== INTEGRATION OAUTH (Revflow) ====================
# Register at: https://revflowapp.com/developers
# Callback URL: https://finos-app.com/api/integrations/revflow/callback
REVFLOW_OAUTH_CLIENT_ID="your-revflow-client-id"
REVFLOW_OAUTH_CLIENT_SECRET="your-revflow-client-secret"
# Canonical URLs — only override for on-premise Revflow instances
REVFLOW_API_BASE="https://revflowapp.com/api/finos"
REVFLOW_TOKEN_URL="https://revflowapp.com/api/oauth/token"
REVFLOW_DISCOVERY_URL="https://revflowapp.com/api/discover"

# ==================== INTEGRATION OAUTH (XpenxFlow) ====================
# Register at: https://xpenxflow.com/developers
# Callback URL: https://finos-app.com/api/integrations/xpenxflow/callback
XPENXFLOW_OAUTH_CLIENT_ID="finos"
XPENXFLOW_OAUTH_CLIENT_SECRET="your-xpenxflow-client-secret"
# Vercel — OAuth pre-approve UI page only (user-facing redirect)
XPENXFLOW_APP_URL="https://xpenseflow-v2-bay.vercel.app"
# Supabase Edge Functions — all backend API + OAuth endpoints
XPENXFLOW_API_BASE="https://gzlhihuabpxzpobtqvql.supabase.co/functions/v1"
XPENXFLOW_TOKEN_URL="https://gzlhihuabpxzpobtqvql.supabase.co/functions/v1/oauth-token"
XPENXFLOW_DISCOVERY_URL="https://gzlhihuabpxzpobtqvql.supabase.co/functions/v1/discover"

# ==================== INTEGRATION OAUTH (EARNMARK360) ====================
# Register at: https://earnmark360.com.ng/developers
# Callback URL: https://finos-app.com/api/integrations/earnmark360/callback
EARNMARK360_OAUTH_CLIENT_ID="finos"
EARNMARK360_OAUTH_CLIENT_SECRET="your-earnmark360-client-secret"
# Canonical URLs — only override for on-premise EARNMARK360 instances
EARNMARK360_APP_URL="https://earnmark360.com.ng"
EARNMARK360_TOKEN_URL="https://earnmark360.com.ng/api/oauth-token"
EARNMARK360_DISCOVERY_URL="https://earnmark360.com.ng/api/discover"

# ==================== INTER-PRODUCT DISCOVERY ====================
# Shared HMAC secret — must be set identically in FINOS and all integrated products.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PRODUCT_DISCOVERY_SECRET="your-64-hex-discovery-secret"

# ==================== BETTYWHYT INTEGRATION ====================
# API key issued by BettyWhyt Perfumes → Settings → API → FINOS Integration Key
BETTYWHYT_API_KEY="bwp_your-64-hex-api-key"
# BettyWhyt platform base URL
BETTYWHYT_BASE_URL="https://bettywhyt.com"
# Shared HMAC-SHA256 secret for inbound webhook validation
# → BettyWhyt sets this as FINOS_WEBHOOK_SECRET in their app
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTYWHYT_WEBHOOK_SECRET="your-64-hex-webhook-secret"
# API key FINOS issues to BettyWhyt — BettyWhyt sets this as FINOS_API_KEY in their app
# Generate: node -e "console.log('finos_' + require('crypto').randomBytes(32).toString('hex'))"
FINOS_API_KEY="finos_your-64-hex-api-key"
