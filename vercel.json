{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["lhr1"],
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    },
    "app/api/integrations/*/sync/route.ts": {
      "maxDuration": 300
    }
  },
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://finos-app.com"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
